# Copy this file to .env and fill in real values. .env is gitignored.
# docker-compose reads it automatically.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-real-environments
POSTGRES_DB=urlshortener

# --- JWT ---
# REQUIRED. Must be at least 32 characters. Generate a strong random value,
# e.g. PowerShell:  [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_SECRET=
JWT_ISSUER=url-shortener
JWT_AUDIENCE=url-shortener

# --- Runtime ---
# Development enables the Hangfire dashboard; Production disables it.
ASPNETCORE_ENVIRONMENT=Production
